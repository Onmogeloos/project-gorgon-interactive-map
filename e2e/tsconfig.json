{
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "strictNullChecks": true,
    "baseUrl": ".",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "es2024",
    "module": "esnext",
    "paths": {
      "@webapp/*": ["../webapp/src/*"],
      "@assets/*": ["../webapp/src/assets/*"],
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
  ],
}