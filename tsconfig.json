{
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "../dist",
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "paths": {
      "@assets/*": ["./src/assets/*"],
      "@types/*": ["./src/types/*"],
      "@components/*": ["./src/components/*"]
    },
    "target": "es2022",
    "module": "es2022"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
  ],
}