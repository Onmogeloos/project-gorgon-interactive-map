{
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "../dist",
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "strictNullChecks": true,
    "baseUrl": ".",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@assets/*": ["./src/assets/*"],
      "@localtypes/*": ["./src/types/*"],
      "@components/*": ["./src/components/*"],
      "@store/*": ["./src/store/*"],
    },
    "target": "es2022",
    "module": "es2022"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
  ],
}